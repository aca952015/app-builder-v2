# Copy this file to .env and fill in real secrets before running the CLI.

# Required unless each model role below has its own API key.
APP_BUILDER_API_KEY=

# Optional OpenAI-compatible endpoint and default model for every role.
APP_BUILDER_BASE_URL=https://api.openai.com/v1
APP_BUILDER_MODEL=openai:gpt-4.1-mini

# Optional role-specific model overrides.
# APP_BUILDER_PLAN_MODEL=openai:gpt-5.4
# APP_BUILDER_GENERATE_MODEL=openai:gpt-4.1-mini
# APP_BUILDER_REPAIR_MODEL=openai:gpt-5.4

# Optional role-specific endpoint overrides.
# APP_BUILDER_PLAN_BASE_URL=https://api.openai.com/v1
# APP_BUILDER_GENERATE_BASE_URL=https://api.openai.com/v1
# APP_BUILDER_REPAIR_BASE_URL=https://api.openai.com/v1

# Optional role-specific API keys.
# APP_BUILDER_PLAN_API_KEY=
# APP_BUILDER_GENERATE_API_KEY=
# APP_BUILDER_REPAIR_API_KEY=

# Optional runtime output controls.
APP_BUILDER_STREAM_MODES=updates,messages,tools,values
APP_BUILDER_STDOUT=dashboard

# Optional interactive runtime validation browser behavior.
# APP_BUILDER_OPEN_BROWSER=true
