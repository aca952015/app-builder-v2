{
  "id": "full-stack",
  "name": "Full-Stack",
  "version": "1.0.0",
  "description": "A deepagents template pack for generating a Next.js + Prisma + SQLite full-stack application.",
  "projectRenderer": "full-stack",
  "repairRetries": {
    "plan": 5,
    "generate": 5
  },
  "phases": {
    "plan": {
      "prompt": "prompts/plan-system-prompt.md",
      "effort": "high"
    },
    "planRepair": {
      "prompt": "prompts/plan-repair-system-prompt.md",
      "effort": "high"
    },
    "generate": {
      "prompt": "prompts/generate-system-prompt.md",
      "effort": "medium"
    },
    "generateRepair": {
      "prompt": "prompts/generate-repair-system-prompt.md",
      "effort": "high"
    }
  },
  "runtimeValidation": {
    "copyEnvExample": true,
    "steps": [
      {
        "name": "pnpm install",
        "command": "pnpm",
        "args": ["install"]
      },
      {
        "name": "pnpm db:init",
        "command": "pnpm",
        "args": ["db:init"]
      },
      {
        "name": "pnpm typecheck",
        "command": "pnpm",
        "args": ["typecheck"]
      },
      {
        "name": "pnpm dev",
        "command": "pnpm",
        "args": ["dev"],
        "kind": "dev-server"
      }
    ]
  },
  "referencesDir": "references",
  "skillsDir": "skills",
  "starterDir": "starter"
}
