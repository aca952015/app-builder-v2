{
  "id": "mini-app",
  "name": "Mini App",
  "version": "1.0.0",
  "description": "A lightweight Next.js mini-app template with a minimal app shell and REST-style endpoints.",
  "projectRenderer": "mini-app",
  "repairRetries": {
    "plan": 5,
    "generate": 5
  },
  "phases": {
    "plan": {
      "prompt": "prompts/plan-system-prompt.md",
      "effort": "max"
    },
    "planRepair": {
      "prompt": "prompts/plan-repair-system-prompt.md",
      "effort": "max"
    },
    "generate": {
      "prompt": "prompts/generate-system-prompt.md",
      "effort": "max"
    },
    "generateRepair": {
      "prompt": "prompts/generate-repair-system-prompt.md",
      "effort": "max"
    }
  },
  "referencesDir": "references",
  "skillsDir": "skills",
  "starterDir": "starter",
  "runtimeValidation": {
    "copyEnvExample": true,
    "steps": [
      {
        "name": "pnpm install",
        "command": "pnpm",
        "args": ["install"]
      },
      {
        "name": "pnpm typecheck",
        "command": "pnpm",
        "args": ["typecheck"]
      },
      {
        "name": "pnpm dev",
        "command": "pnpm",
        "args": ["dev"],
        "kind": "dev-server"
      }
    ]
  },
  "interactiveRuntimeValidation": {
    "enabled": true,
    "coverageThreshold": 0.8,
    "idleTimeoutMs": 10000,
    "readyTimeoutMs": 90000
  }
}
