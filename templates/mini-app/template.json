{
  "id": "mini-app",
  "name": "Mini App",
  "version": "1.0.0",
  "description": "A lightweight Next.js mini-app template with a minimal app shell and REST-style endpoints.",
  "projectRenderer": "mini-app",
  "prompts": {
    "plan": "prompts/plan-system-prompt.md",
    "planRepair": "prompts/plan-repair-system-prompt.md",
    "generate": "prompts/generate-system-prompt.md",
    "generateRepair": "prompts/generate-repair-system-prompt.md"
  },
  "referencesDir": "references",
  "starterDir": "starter",
  "runtimeValidation": {
    "copyEnvExample": true,
    "steps": [
      {
        "name": "pnpm install",
        "command": "pnpm",
        "args": ["install"]
      },
      {
        "name": "pnpm dev",
        "command": "pnpm",
        "args": ["dev"],
        "kind": "dev-server"
      }
    ]
  }
}
