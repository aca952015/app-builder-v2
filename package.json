{
  "name": "app-builder-v2",
  "version": "0.1.0",
  "description": "PRD-driven full-stack app generator CLI",
  "type": "module",
  "bin": {
    "app-builder": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build --silent && node dist/tests/env.test.js && node dist/tests/parser.test.js && node dist/tests/generator.test.js",
    "lint": "node ./scripts/lint.mjs",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/openai": "^1.4.4",
    "deepagents": "^1.9.0",
    "ink": "^7.0.0",
    "langchain": "^1.3.1",
    "react": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.3"
  }
}
